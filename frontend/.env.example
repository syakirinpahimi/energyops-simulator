# =============================================================================
# Frontend (Next.js) - environment template
# Copy to `.env.local` for local dev. Docker compose injects these via
# the root .env file.
# =============================================================================

# Base URL of the FastAPI backend (REST). No trailing slash.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# WebSocket URL for /ws/telemetry. No trailing slash.
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# When set to "1", the API client returns deterministic mock data instead of
# calling the backend. ONLY for local UI development before backend is up.
# Never enable in production builds.
NEXT_PUBLIC_USE_MOCKS=1

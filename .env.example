# =============================================================================
# Industrial EnergyOps Dashboard — environment template
# Copy this file to `.env` and fill in real values before running docker compose.
# =============================================================================

# --- PostgreSQL / TimescaleDB ---
POSTGRES_USER=energyops
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=energyops
POSTGRES_PORT=5432

# --- MQTT (Mosquitto) ---
MQTT_PORT=1883
MQTT_WS_PORT=9001
MQTT_USERNAME=energyops
MQTT_PASSWORD=changeme_mqtt

# --- Backend (FastAPI) ---
BACKEND_PORT=8000
JWT_SECRET=replace_with_long_random_string_min_32_chars
JWT_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
# Set to 0 / false / no to skip the MQTT consumer (useful for unit tests
# and laptop dev without a broker). Default is 1.
MQTT_ENABLED=1

# --- Frontend (Next.js) ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- Simulator ---
# Tick interval in seconds between telemetry publishes per asset.
SIM_TICK_SECONDS=5
# Probability per tick that an asset emits a fault event (0.0 - 1.0).
SIM_FAULT_PROBABILITY=0.01

# --- Seeded demo users (used by backend seed script) ---
SEED_ADMIN_EMAIL=admin@energyops.local
SEED_ADMIN_PASSWORD=Admin#12345
SEED_MANAGER_EMAIL=manager@energyops.local
SEED_MANAGER_PASSWORD=Manager#12345
SEED_ENGINEER_EMAIL=engineer@energyops.local
SEED_ENGINEER_PASSWORD=Engineer#12345
SEED_OPERATOR_EMAIL=operator@energyops.local
SEED_OPERATOR_PASSWORD=Operator#12345
